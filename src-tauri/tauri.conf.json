{
  "productName": "Snapforge",
  "version": "1.3.0",
  "identifier": "com.snapforge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": []
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/user/snapforge/releases/latest/download/latest.json"],
      "pubkey": ""
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "macOS": {
      "entitlements": null,
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "timestampUrl": "http://timestamp.digicert.com"
    }
  }
}
